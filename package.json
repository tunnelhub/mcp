{
  "name": "@tunnelhub/mcp",
  "version": "1.0.3",
  "description": "MCP server for TunnelHub automations and monitoring",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "mcp": "dist/index.js",
    "tunnelhub-mcp": "dist/index.js"
  },
  "type": "module",
  "scripts": {
    "clean": "rm -rf dist",
    "dev": "tsx watch src/index.ts",
    "build": "pnpm run clean && tsc",
    "start": "node dist/index.js",
    "test": "jest --passWithNoTests",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "check": "pnpm run lint && pnpm run typecheck && pnpm run test && pnpm run build",
    "prepack": "pnpm run check",
    "prepublishOnly": "pnpm run check",
    "pack:check": "npm pack --dry-run",
    "publish:dry-run": "npm publish --dry-run --access public",
    "release:patch": "npm version patch",
    "release:minor": "npm version minor",
    "release:major": "npm version major"
  },
  "files": [
    "dist/**/*",
    "README.md",
    "LICENSE",
    "CONTRIBUTING.md"
  ],
  "keywords": [
    "mcp",
    "tunnelhub",
    "model-context-protocol",
    "automation",
    "monitoring",
    "observability"
  ],
  "author": "TunnelHub",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tunnelhub/mcp.git"
  },
  "homepage": "https://github.com/tunnelhub/mcp#readme",
  "bugs": {
    "url": "https://github.com/tunnelhub/mcp/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "@aws-sdk/client-cognito-identity-provider": "^3.693.0",
    "axios": "^1.7.9",
    "chalk": "^5.3.0",
    "configstore": "^7.0.0",
    "express": "^4.21.2",
    "open": "^10.1.0",
    "uuid": "^11.0.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/configstore": "^6.0.2",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.5",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.20.0",
    "@typescript-eslint/parser": "^8.20.0",
    "eslint": "^8.57.1",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@10.8.1"
}
