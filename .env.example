# TunnelHub MCP Server Configuration

# Development settings
NODE_ENV=development
LOG_LEVEL=debug

# OAuth callback port (default: 3333)
OAUTH_CALLBACK_PORT=3333

# API endpoints (optional - will be determined by tenant selection)
# TUNNELHUB_API_HOST=https://api.tunnelhub.io
# TUNNELHUB_API_HOST_DEV=https://api.dev.tunnelhub.io
# TUNNELHUB_API_HOST_QAS=https://api.qas.tunnelhub.io